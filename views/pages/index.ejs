  <%# --- BONUS 12: Sectiune Oferta cu Temporizator --- %>
  <% if (locals.oferta && oferta) { %>
  <section id="oferta-timer" class="container mt-5 mb-4 p-4 rounded shadow" style="background: linear-gradient(135deg, #1e293b, #334155); color:white; text-align:center;">
      <h3><i class="bi bi-lightning-charge-fill" style="color:#fbbf24;"></i> Ofertă Specială!</h3>
      <p class="lead mb-2">
          <span class="badge bg-danger" style="font-size:1.2em; padding:8px 16px;"><%= oferta.reducere %>% REDUCERE</span>
          la categoria <strong style="color:#fbbf24;"><%= oferta.categorie %></strong>
      </p>
      <p class="mb-3">Oferta expiră în:</p>
      <div id="countdown-oferta" style="font-size:2.5em; font-weight:bold; font-family:monospace; letter-spacing:3px; transition: color 0.3s;">
          00:00:00
      </div>
      <p class="mt-2 mb-0"><a href="/produse?categorie=<%= oferta.categorie %>" class="btn btn-warning btn-lg mt-2"><i class="bi bi-cart-fill"></i> Vezi produsele</a></p>
  </section>
  <script>
  (function() {
      let dataFinalizare = new Date('<%= oferta["data-finalizare"] %>');
      let countdownEl = document.getElementById('countdown-oferta');
      let sectiuneOferta = document.getElementById('oferta-timer');
      
      function actualizeazaTimer() {
          let acum = new Date();
          let diff = dataFinalizare - acum;
          
          if (diff <= 0) {
              // Oferta a expirat - fetch oferta noua
              countdownEl.textContent = 'EXPIR\u0102!';
              countdownEl.style.color = '#ef4444';
              setTimeout(function() {
                  fetch('/api/oferta-curenta')
                      .then(r => r.json())
                      .then(data => {
                          if (data && !data.expired) {
                              // Reload pagina pt noua oferta
                              location.reload();
                          } else {
                              sectiuneOferta.style.display = 'none';
                          }
                      })
                      .catch(() => { sectiuneOferta.style.display = 'none'; });
              }, 3000);
              return;
          }
          
          let secunde = Math.floor(diff / 1000);
          let ore = Math.floor(secunde / 3600);
          let min = Math.floor((secunde % 3600) / 60);
          let sec = secunde % 60;
          
          countdownEl.textContent = 
              String(ore).padStart(2, '0') + ':' + 
              String(min).padStart(2, '0') + ':' + 
              String(sec).padStart(2, '0');
          
          // Ultimele 10 secunde - marcaj diferit
          if (secunde <= 10) {
              countdownEl.style.color = '#ef4444';
              countdownEl.style.animation = 'pulse-countdown 0.5s infinite';
          } else {
              countdownEl.style.color = '#fbbf24';
              countdownEl.style.animation = 'none';
          }
      }
      
      actualizeazaTimer();
      setInterval(actualizeazaTimer, 1000);
  })();
  </script>
  <style>
      @keyframes pulse-countdown {
          0%, 100% { transform: scale(1); opacity: 1; }
          50% { transform: scale(1.15); opacity: 0.7; }
      }
  </style>
  <% } %>

