<!DOCTYPE html>
<html lang="ro">
<head>
    <title>Eroare - Handball Gear</title>
    <%- include("../fragments/head.ejs") %>
    
    <style>
        /* Un pic de stilizare specifică pentru a centra eroarea frumos */
        .sectiune-eroare {
            text-align: center;
            padding: 5rem 1rem;
            min-height: 50vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .sectiune-eroare img {
            max-width: 150px;
            margin-bottom: 2rem;
            filter: drop-shadow(0 0 10px rgba(0,0,0,0.2));
        }
        .sectiune-eroare h2 {
            color: var(--culoare-highlight, red); /* Folosește variabila ta, sau roșu */
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        .sectiune-eroare p {
            font-size: 1.2rem;
            max-width: 600px;
        }
    </style>
</head>

<body id="top">
    <%- include("../fragments/header.ejs") %>

    <main>
        <section class="sectiune-eroare">
            <div id="err-imag">
                <img src="<%- locals.imagine %>" alt="Eroare" />
            </div>
            <h2><%- locals.titlu %></h2>
            <p><%- locals.text %></p>
            <br>
            <a href="/index" class="btn-tab" style="padding: 10px 20px; font-weight: bold;">Întoarce-te pe Acasă</a>
        </section>
    </main>

    <%- include("../fragments/footer.ejs") %>
</body>
</html>