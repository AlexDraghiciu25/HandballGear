<script>
// Script pentru Teme Multiple (Bonus 2) - salvare in localStorage
document.addEventListener("DOMContentLoaded", function() {
    const selectTema = document.getElementById("select-tema");
    
    // Verificăm ce e salvat în localStorage
    let temaCurenta = localStorage.getItem("tema_site") || "light";
    
    // Aplicăm tema salvată
    if (temaCurenta && temaCurenta !== "light") {
        document.documentElement.setAttribute("data-theme", temaCurenta);
        document.body.setAttribute("data-theme", temaCurenta);
    }
    if (selectTema) selectTema.value = temaCurenta;

    // La schimbarea select-ului
    if (selectTema) {
        selectTema.addEventListener("change", function() {
            let temaNoua = this.value;
            if (temaNoua === "light") {
                document.documentElement.removeAttribute("data-theme");
                document.body.removeAttribute("data-theme");
            } else {
                document.documentElement.setAttribute("data-theme", temaNoua);
                document.body.setAttribute("data-theme", temaNoua);
            }
            localStorage.setItem("tema_site", temaNoua);
        });
    }
});
</script>